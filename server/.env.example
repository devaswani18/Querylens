DATABASE_URL=                  # superuser/admin — used only for setup scripts (schema.sql, seed.sql), NOT by the running app
DATABASE_URL_READONLY=         # querylens_readonly role — used by /api/query/execute and /api/explain
DATABASE_URL_INDEX_MANAGER=    # querylens_index_manager role — used only by /api/apply-index
GEMINI_API_KEY=
PORT=3001
NODE_ENV=development
FRONTEND_ORIGIN=               # required in production — e.g. https://querylens.vercel.app